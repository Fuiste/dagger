{
  "name": "@fuiste/dagger",
  "version": "1.0.0",
  "type": "module",
  "description": "Event-sourced DAG execution engine for agent chats, routing specialist tasks across Codex and Cursor.",
  "bin": {
    "dagger": "./bin/dagger.js"
  },
  "exports": {
    ".": "./src/v1/index.ts"
  },
  "files": [
    "bin",
    "docs",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Fuiste/dagger.git"
  },
  "bugs": {
    "url": "https://github.com/Fuiste/dagger/issues"
  },
  "homepage": "https://github.com/Fuiste/dagger#readme",
  "keywords": [
    "cli",
    "codex",
    "cursor",
    "dag",
    "effect",
    "orchestration"
  ],
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "benchmark:preflight": "bun run src/benchmark/cli.ts preflight",
    "benchmark:run": "bun run src/benchmark/cli.ts run",
    "benchmark:report": "bun run src/benchmark/cli.ts report",
    "benchmark:tasks": "bun run src/benchmark/cli.ts tasks",
    "check": "tsc --noEmit",
    "test": "bun test",
    "start": "bun run src/index.ts",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.50",
    "effect": "^4.0.0-beta.50",
    "markdown-it": "^14.1.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  }
}
